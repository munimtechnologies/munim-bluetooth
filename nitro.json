{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "munimbluetooth"
  ],
  "ios": {
    "iosModuleName": "MunimBluetooth"
  },
  "android": {
    "androidNamespace": [
      "munimbluetooth"
    ],
    "androidCxxLibName": "MunimBluetooth"
  },
  "autolinking": {
    "MunimBluetooth": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridMunimBluetooth"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridMunimBluetooth"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
